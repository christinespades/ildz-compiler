
typedef enum {
    IR_OP_IMM,          // Load a literal integer into a virtual register
    IR_OP_ADD,          // v_dest = v_src1 + v_src2
    IR_OP_SUB,          // v_dest = v_src1 - v_src2
    IR_OP_MUL,          // v_dest = v_src1 * v_src2
    IR_OP_DIV,          // v_dest = v_src1 / v_src2
    IR_OP_ASSIGN,       // v_dest = v_src1
    IR_OP_LOAD,
    IR_OP_STORE,
    IR_OP_LABEL,        // Marker for jump targets (uses dest_vreg as Label ID)
    IR_OP_JMP,          // Unconditional jump to a Label ID
    IR_OP_JMP_IF_ZERO,  // Jump to Label ID if v_src1 == 0
    IR_OP_RETURN        // Return from function (uses v_src1)
} IROpcode;

typedef enum {
    OPERAND_NONE,
    OPERAND_VREG,       // Value is inside a virtual register
    OPERAND_INT         // Value is an immediate literal integer constant
} IRKind;

typedef struct {
    IRKind kind;
    union {
        u32 vreg;       // Virtual register index (v0, v1, v2...)
        i64 imm_int;    // Literal value
    };
} IROperand;

typedef struct {
    IROpcode op;
    u32 dest_vreg;      // Destination virtual register (if applicable)
    IROperand src1;
    IROperand src2;
} IRInstruction;

typedef struct {
    IRInstruction* instructions;
    u32 count;
    u32 capacity;
    u32 next_vreg_id;   // Monotonically increasing counter for unique vregs
    u32 next_label_id;  // Monotonically increasing counter for unique jump labels
} IRProgram;

void ir_init(IRProgram* prog, Arena* arena) {
    prog->capacity = 1024; // Start with a clean page of instructions
    prog->count = 0;
    prog->next_vreg_id = 0;
    prog->next_label_id = 0;
    prog->instructions = (IRInstruction*)arena_alloc(arena, prog->capacity * sizeof(IRInstruction));
}

u32 ir_new_vreg(IRProgram* prog) {
    return prog->next_vreg_id++;
}

u32 ir_new_label(IRProgram* prog) {
    return prog->next_label_id++;
}

static void ir_emit(IRProgram* prog, Arena* arena, IRInstruction inst) {
    if (prog->count >= prog->capacity) {
        // Grow capacity by doubling
        u32 old_capacity = prog->capacity;
        prog->capacity *= 2;
        
        IRInstruction* new_insts = (IRInstruction*)arena_alloc(arena, prog->capacity * sizeof(IRInstruction));
        // Simple memory copy without string.h dependencies
        for (u32 i = 0; i < old_capacity; i++) {
            new_insts[i] = prog->instructions[i];
        }
        prog->instructions = new_insts;
    }
    prog->instructions[prog->count++] = inst;
}

// Quick Helper API for lowering phases
u32 ir_emit_imm(IRProgram* prog, Arena* arena, i64 literal) {
    u32 dest = ir_new_vreg(prog);
    IRInstruction inst = {
        .op = IR_OP_IMM,
        .dest_vreg = dest,
        .src1 = { .kind = OPERAND_INT, .imm_int = literal },
        .src2 = { .kind = OPERAND_NONE }
    };
    ir_emit(prog, arena, inst);
    return dest;
}

u32 ir_emit_binop(IRProgram* prog, Arena* arena, IROpcode op, u32 src1_vreg, u32 src2_vreg) {
    u32 dest = ir_new_vreg(prog);
    IRInstruction inst = {
        .op = op,
        .dest_vreg = dest,
        .src1 = { .kind = OPERAND_VREG, .vreg = src1_vreg },
        .src2 = { .kind = OPERAND_VREG, .vreg = src2_vreg }
    };
    ir_emit(prog, arena, inst);
    return dest;
}


typedef struct
{
    IRProgram* prog;
    Arena* arena;

    struct {
        const char* name;
        u32 vreg;
    } variables[1024];

    u32 variable_count;

} IRLowerContext;

// Evaluates an AST statement or expression tree and returns the resulting virtual register ID
u32 lower_ast_to_ir(IRLowerContext* ctx, ASTNode* node) {
    if (!node) return 0;

    switch (node->type) {
        case NODE_PROGRAM: {
            loginf("[IR Lowering] Entering NODE_PROGRAM node tree root...");
            ASTNode* current = node->children;
            u32 final_reg = 0;
            
            while (current) {
                final_reg = lower_ast_to_ir(ctx, current);
                current = current->next;
            }
            
            // If the program generated code, automatically append an explicit terminal return
            if (ctx->prog->count > 0) {
                loginf("[IR Lowering] Synthesizing terminal function return path.");
                IRInstruction return_inst = {
                    .op = IR_OP_RETURN,
                    .dest_vreg = 0,
                    .src1 = { .kind = OPERAND_VREG, .vreg = final_reg },
                    .src2 = { .kind = OPERAND_NONE }
                };
                ir_emit(ctx->prog, ctx->arena, return_inst);
            }
            return final_reg;
        }

        case NODE_LITERAL_INT: {
            loginf("[IR Lowering] Emitting Immediate Integer constant load operation.");
            return ir_emit_imm(ctx->prog, ctx->arena, node->as.int_value);
        }

        case NODE_BINARY_OP: {
            ASTNode* left  = node->children;
            ASTNode* right = left ? left->next : NULL;

            u32 left_reg  = lower_ast_to_ir(ctx, left);
            u32 right_reg = lower_ast_to_ir(ctx, right);
            
            IROpcode op;
            if (node->lexeme.length == 1)
            {
                switch (node->lexeme.data[0])
                {
                    case '+':
                        loginf("[IR Lowering] Emitting Register Binary Operator: ADD (+)");
                        op = IR_OP_ADD;
                        break;

                    case '-':
                        loginf("[IR Lowering] Emitting Register Binary Operator: SUB (-)");
                        op = IR_OP_SUB;
                        break;

                    case '*':
                        loginf("[IR Lowering] Emitting Register Binary Operator: MUL (*)");
                        op = IR_OP_MUL;
                        break;

                    case '/':
                        loginf("[IR Lowering] Emitting Register Binary Operator: DIV (/)");
                        op = IR_OP_DIV;
                        break;

                    default:
                        logerr("Lowering Error: Unknown or unhandled binary operator variant.");
                        ExitProcess(1);
                }
            }
            return ir_emit_binop(ctx->prog, ctx->arena, op, left_reg, right_reg);
        }

        case NODE_ASSIGNMENT: {
            loginf("[IR Lowering] Processing explicit local Variable Assignment.");
            u32 value_reg = lower_ast_to_ir(ctx, node->children);
            u32 dest_reg = ir_new_vreg(ctx->prog);
            
            IRInstruction inst = {
                .op = IR_OP_ASSIGN,
                .dest_vreg = dest_reg,
                .src1 = { .kind = OPERAND_VREG, .vreg = value_reg },
                .src2 = { .kind = OPERAND_NONE }
            };
            ir_emit(ctx->prog, ctx->arena, inst);
            return dest_reg;
        }
        case NODE_IF:
        {
            ASTNode* condition = node->children;
            ASTNode* body = condition->next;

            u32 cond = lower_ast_to_ir(ctx, condition);

            u32 end_label = ir_new_label(ctx->prog);

            IRInstruction jump = {
                .op = IR_OP_JMP_IF_ZERO,
                .src1 = { .kind = OPERAND_VREG, .vreg = cond },
                .dest_vreg = end_label
            };

            ir_emit(ctx->prog, ctx->arena, jump);

            lower_ast_to_ir(ctx, body);

            IRInstruction label = {
                .op = IR_OP_LABEL,
                .dest_vreg = end_label
            };

            ir_emit(ctx->prog, ctx->arena, label);

            return 0;
        }
        case NODE_RETURN:
        {
            u32 value = lower_ast_to_ir(ctx, node->children);

            IRInstruction inst = {
                .op = IR_OP_RETURN,
                .src1 = {
                    .kind = OPERAND_VREG,
                    .vreg = value
                }
            };

            ir_emit(ctx->prog, ctx->arena, inst);

            return value;
        }
        default:
            if (node->children) lower_ast_to_ir(ctx, node->children);
            return 0;
    }
}


// Global AST walker traversing all parsed compilation unit blocks
static void resolve_ast_dependencies(ASTNode* node) {
    if (!node) return;

    // If we hit an identifier or call node, register its reference
    if (node->type == NODE_CALL || node->type == NODE_IDENTIFIER) {
        increment_symbol_reference(node->lexeme);
    }

    resolve_ast_dependencies(node->children);
    resolve_ast_dependencies(node->next);
}

// Dead Code Elimination (DCE) Pass using your exact structural arrays
void execute_global_dead_code_elimination(void) {
    loginf("[Semantic Analysis] Scanning global AST compilation units for dead code blocks...");

    // Pass 1: Crawl through every registered AST root to calculate exact call frequencies
    for (u32 i = 0; i < g_ast_root_count; i++) {
        if (g_ast_roots[i]) {
            resolve_ast_dependencies(g_ast_roots[i]->children);
        }
    }

    // Pass 2: Prune the unreferenced function nodes directly out of the AST chains
    for (u32 i = 0; i < g_ast_root_count; i++) {
        if (!g_ast_roots[i]) continue;

        ASTNode* prev = NULL;
        ASTNode* current = g_ast_roots[i]->children;

        while (current) {
            if (current->type == NODE_FUNCTION) {
                // Find matching definition metadata inside your symbol registry
                Symbol* definition_sym = NULL;
                for (u32 s = 0; s < g_symbol_count; s++) {
                    if (g_symbol_registry[s].is_function_decl && g_symbol_registry[s].node == current) {
                        definition_sym = &g_symbol_registry[s];
                        break;
                    }
                }

                // If a function declaration has 0 calls (and isn't explicitly 'main'), eliminate it
                if (definition_sym && definition_sym->ref_count == 0) {
                    loginf("[Dead Code Elimination] Pruning uncalled function ", definition_sym->target_sv, " from compilation stream.");

                    // Safely slice the node completely out of your execution chain
                    if (prev == NULL) {
                        g_ast_roots[i]->children = current->next;
                    } else {
                        prev->next = current->next;
                    }
                    
                    current = current->next;
                    continue;
                }
            }
            prev = current;
            current = current->next;
        }
    }
}
