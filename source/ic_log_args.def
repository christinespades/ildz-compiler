MAKE_ENUM(
    LOG_ARG,
    LogArgType,
    log_arg_type_names,
    BOOL,
    INT8,
    UINT8,
    INT16,
    UINT16,
    INT32,
    UINT32,
    INT64,
    UINT64,
    FLOAT,
    DOUBLE,
    STRING,
    UNKNOWN,
    VEC2,
    VEC3,
    VEC4,
    WSTRING,
    STRING_VIEW,
);

typedef struct
{
    const char* name;
    LogArgType type;
    union
    {
        bool b;
        int8_t i8;
        uint8_t u8;
        int16_t i16;
        uint16_t u16;
        int32_t i32;
        uint32_t u32;
        int64_t i64;
        uint64_t u64;
        float f;
        double d;
        const char* s;
        const wchar_t* ws;
        void* x;
        vec2 v2;
        vec3 v3;
        vec4 v4;
        struct
        {
            const char* data;
            u32 length;
        } sv;
    };
} LogArg;

static void log_print_arg(const LogArg* arg)
{
    if (arg->name) {
        log_write_string(arg->name);
        log_write_string("=");
    }

    switch (arg->type)
    {
        case LOG_ARG_BOOL:
            log_write_string(arg->b ? "true" : "false");
            break;
        case LOG_ARG_INT8:
            log_write_int64((int64_t)arg->i8);
            break;
        case LOG_ARG_UINT8:
            log_write_uint64((uint64_t)arg->u8);
            break;
        case LOG_ARG_INT16:
            log_write_int64((int64_t)arg->i16);
            break;
        case LOG_ARG_UINT16:
            log_write_uint64((uint64_t)arg->u16);
            break;
        case LOG_ARG_INT32:
            log_write_int64((int64_t)arg->i32);
            break;
        case LOG_ARG_UINT32:
            log_write_uint64((uint64_t)arg->u32);
            break;
        case LOG_ARG_INT64:
            log_write_int64(arg->i64);
            break;
        case LOG_ARG_UINT64:
            log_write_uint64(arg->u64);
            break;
        case LOG_ARG_FLOAT:
            log_write_double((double)arg->f);
            break;
        case LOG_ARG_DOUBLE:
            log_write_double(arg->d);
            break;
        case LOG_ARG_STRING:
            log_write_string(arg->s ? arg->s : "(null)");
            break;
        case LOG_ARG_STRING_VIEW:
            log_write_string_view(arg->sv.data, arg->sv.length);
            break;
        case LOG_ARG_UNKNOWN:
            log_write_hex((uintptr_t)arg->x);
            break;
        case LOG_ARG_WSTRING:
            log_write_wstring(arg->ws);
            break;
        case LOG_ARG_VEC2:
            log_write_string("(");
            log_write_double((double)arg->v2.x);
            log_write_string(", ");
            log_write_double((double)arg->v2.y);
            log_write_string(")");
            break;
        case LOG_ARG_VEC3:
            log_write_string("(");
            log_write_double((double)arg->v3.x);
            log_write_string(", ");
            log_write_double((double)arg->v3.y);
            log_write_string(", ");
            log_write_double((double)arg->v3.z);
            log_write_string(")");
            break;
        case LOG_ARG_VEC4:
            log_write_string("(");
            log_write_double((double)arg->v4.x);
            log_write_string(", ");
            log_write_double((double)arg->v4.y);
            log_write_string(", ");
            log_write_double((double)arg->v4.z);
            log_write_string(", ");
            log_write_double((double)arg->v4.w);
            log_write_string(")");
            break;
    }
}

static void log_write_args(const LogArg* args, uint32_t count, bool cycle_color)
{
    for (uint32_t i = 0; i < count; i++)
    {
        log_print_arg(&args[i]);
        if (cycle_color) log_cycle_color();
    }
}

