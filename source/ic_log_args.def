static void log_print(const char* fmt, const LogArg* args, uint32_t arg_count)
{
    uint32_t arg = 0;
    while (*fmt)
    {
        /* escaped '{' */
        if (fmt[0] == '{' && fmt[1] == '{')
        {
            log_putc('{');
            fmt += 2;
            continue;
        }
        /* escaped '}' */
        if (fmt[0] == '}' && fmt[1] == '}')
        {
            log_putc('}');
            fmt += 2;
            continue;
        }
        /* placeholder */
        if (fmt[0] == '{' && fmt[1] == '}')
        {
            if (arg < arg_count)
            {
                log_print_arg(&args[arg++]);
            }
            else
            {
                log_write_string("<missing>");
            }

            fmt += 2;
            continue;
        }
        log_putc(*fmt++);
    }
    /* Warn about unused arguments */
    if (arg < arg_count)
    {
        log_write_string(" <extra:");
        while (arg < arg_count)
        {
            log_putc(' ');
            log_print_arg(&args[arg++]);
        }
        log_putc('>');
    }
}


#define LOG_ARG_SCALAR(fn, enum_type, value_type, member) \
static inline LogArg fn(value_type v)                     \
{                                                         \
    return (LogArg){ .type = enum_type, .member = v };    \
}
LOG_ARG_SCALAR(log_arg_bool,    LOG_ARG_BOOL,    bool,         b)
LOG_ARG_SCALAR(log_arg_int8,    LOG_ARG_INT8,    int8_t,       i8)
LOG_ARG_SCALAR(log_arg_uint8,   LOG_ARG_UINT8,   uint8_t,      u8)
LOG_ARG_SCALAR(log_arg_int16,   LOG_ARG_INT16,   int16_t,      i16)
LOG_ARG_SCALAR(log_arg_uint16,  LOG_ARG_UINT16,  uint16_t,     u16)
LOG_ARG_SCALAR(log_arg_int32,   LOG_ARG_INT32,   int32_t,      i32)
LOG_ARG_SCALAR(log_arg_uint32,  LOG_ARG_UINT32,  uint32_t,     u32)
LOG_ARG_SCALAR(log_arg_int64,   LOG_ARG_INT64,   int64_t,      i64)
LOG_ARG_SCALAR(log_arg_uint64,  LOG_ARG_UINT64,  uint64_t,     u64)
LOG_ARG_SCALAR(log_arg_float,   LOG_ARG_FLOAT,   float,        f)
LOG_ARG_SCALAR(log_arg_double,  LOG_ARG_DOUBLE,  double,       d)
LOG_ARG_SCALAR(log_arg_string,  LOG_ARG_STRING,  const char*,  s)
LOG_ARG_SCALAR(log_arg_unknown, LOG_ARG_UNKNOWN, void*,        x)
LOG_ARG_SCALAR(log_arg_vec2,    LOG_ARG_VEC2,    vec2,         v2)
LOG_ARG_SCALAR(log_arg_vec3,    LOG_ARG_VEC3,    vec3,         v3)
LOG_ARG_SCALAR(log_arg_vec4,    LOG_ARG_VEC4,    vec4,         v4)
LOG_ARG_SCALAR(log_arg_wstring, LOG_ARG_WSTRING, const wchar_t*, ws)
#undef LOG_ARG_SCALAR
static inline LogArg log_arg_string_view(StringView sv)
{
    LogArg arg = {0};
    arg.type = LOG_ARG_STRING_VIEW;
    arg.sv.data = sv.data;
    arg.sv.length = sv.length;
    return arg;
}
#define LOG_ARG_VEC_STD140(fn, enum_type, src_type, member, ...) \
static inline LogArg fn(src_type v)                             \
{                                                              \
    return (LogArg){                                           \
        .type = enum_type,                                     \
        .member = { __VA_ARGS__ }                              \
    };                                                         \
}
LOG_ARG_VEC_STD140(log_arg_vec2std140, LOG_ARG_VEC2, Vec2Std140, v2, v.x, v.y)
LOG_ARG_VEC_STD140(log_arg_vec3std140, LOG_ARG_VEC3, Vec3Std140, v3, v.x, v.y, v.z)
LOG_ARG_VEC_STD140(log_arg_vec4std140, LOG_ARG_VEC4, Vec4Std140, v4, v.x, v.y, v.z, v.w)

static inline LogArg log_arg_vk_result(VkResult result)
{
    return (LogArg)
    {
        .type = LOG_ARG_UINT64,
        .u64 = result
    };
}
static inline LogArg log_arg_passthrough(LogArg arg)
{
    return arg;
}
#define LOG_ARG_PTR(fn, base_fn, type) \
static inline LogArg fn(type* v)       \
{                                      \
    return base_fn(*v);                \
}

LOG_ARG_PTR(log_arg_bool_ptr,   log_arg_bool,   bool)
LOG_ARG_PTR(log_arg_int32_ptr,  log_arg_int32,  int32_t)
LOG_ARG_PTR(log_arg_uint32_ptr, log_arg_uint32, uint32_t)
LOG_ARG_PTR(log_arg_float_ptr,  log_arg_float,  float)
LOG_ARG_PTR(log_arg_double_ptr, log_arg_double, double)
LOG_ARG_PTR(log_arg_vec2_ptr,   log_arg_vec2,   vec2)
LOG_ARG_PTR(log_arg_vec3_ptr,   log_arg_vec3,   vec3)
LOG_ARG_PTR(log_arg_vec4_ptr,   log_arg_vec4,   vec4)
static inline LogArg log_arg_size(size_t v)
{
    return log_arg_uint64((uint64_t)v);
}

#define LOG_VK(x) log_arg_vk_result(x)

#define LOG_ARG(x) \
    _Generic((x), \
        bool:       log_arg_bool, \
        bool*:      log_arg_bool_ptr, \
        int32_t:    log_arg_int32, \
        int32_t*:   log_arg_int32_ptr, \
        uint32_t:   log_arg_uint32, \
        uint32_t*:  log_arg_uint32_ptr, \
        float:      log_arg_float, \
        float*:     log_arg_float_ptr, \
        double:     log_arg_double, \
        double*:    log_arg_double_ptr, \
        vec2:       log_arg_vec2, \
        vec2*:      log_arg_vec2_ptr, \
        vec3:       log_arg_vec3, \
        vec3*:      log_arg_vec3_ptr, \
        vec4:       log_arg_vec4, \
        vec4*:      log_arg_vec4_ptr, \
        char*:              log_arg_string, \
        const char*:        log_arg_string, \
        wchar_t*:   log_arg_wstring, \
        const wchar_t*: log_arg_wstring, \
        char[1]:            log_arg_string, \
        const char[1]:      log_arg_string, \
        Vec2Std140:         log_arg_vec2std140, \
        Vec3Std140:         log_arg_vec3std140, \
        Vec4Std140:         log_arg_vec4std140, \
        unsigned long:      log_arg_uint32, \
        __int64: log_arg_int64, \
        unsigned __int64: log_arg_uint64, \
        StringView: log_arg_string_view, \
        LogArg: log_arg_passthrough \
    )(x)
    
static inline LogArg log_arg_named(const char* name, LogArg arg)
{
    arg.name = name;
    return arg;
}

static const char* g_debug_log_filter[] =
{
    "watcher.c"
};

static inline bool log_allowed(const char* file)
{
    for (uint32_t i = 0; i < sizeof(g_debug_log_filter) / sizeof(g_debug_log_filter[0]); i++)
    {
        if (string_in_string(file, g_debug_log_filter[i]))
            return false;
    }

    return true;
}
