
static void log_rgb_color(uint8_t r, uint8_t g, uint8_t b)
{
    log_write_string("\x1b[38;2;");
    log_write_uint64(r);
    log_write_string(";");
    log_write_uint64(g);
    log_write_string(";");
    log_write_uint64(b);
    log_write_string("m");
}

MAKE_ENUM(
    COLOR,
    ColorType,
    color_type_names,
    CYCLE,
    BLUE,
    GREEN,
    PURPLE,
    RED,
    YELLOW,
    CYAN
);

static void log_cycle_color_ex(ColorType col)
{
    static float hue = 0.0f;

    float start_hue = 0.0f;
    float range = 360.0f;

    switch (col)
    {
        case COLOR_RED:
            start_hue = 0.0f;
            range = 30.0f;
            break;

        case COLOR_YELLOW:
            start_hue = 60.0f;
            range = 30.0f;
            break;

        case COLOR_GREEN:
            start_hue = 120.0f;
            range = 30.0f;
            break;

        case COLOR_CYAN:
            start_hue = 180.0f;
            range = 30.0f;
            break;

        case COLOR_BLUE:
            start_hue = 240.0f;
            range = 30.0f;
            break;

        case COLOR_PURPLE:
            start_hue = 300.0f;
            range = 30.0f;
            break;

        default:
            start_hue = 0.0f;
            range = 360.0f;
            break;
    }

    float local_hue = start_hue + ildz_modf(hue, range);

    float s = 1.0f;
    float v = 1.0f;

    float c = v * s;
    float x = c * (1.0f - ildz_absf(ildz_modf(local_hue / 60.0f, 2.0f) - 1.0f));
    float m = v - c;

    float r, g, b;

    if (local_hue < 60)       { r = c; g = x; b = 0; }
    else if (local_hue < 120) { r = x; g = c; b = 0; }
    else if (local_hue < 180) { r = 0; g = c; b = x; }
    else if (local_hue < 240) { r = 0; g = x; b = c; }
    else if (local_hue < 300) { r = x; g = 0; b = c; }
    else                      { r = c; g = 0; b = x; }

    hue += 10.0f;

    log_rgb_color(
        (uint8_t)((r + m) * 255),
        (uint8_t)((g + m) * 255),
        (uint8_t)((b + m) * 255)
    );
}

#define log_cycle_color()     log_cycle_color_ex(COLOR_CYCLE)
#define log_cycle_color_type(c) log_cycle_color_ex(c)
