bool compile_file(const char* path, ASTNode** out_ast_root, Arena* arena)
{
    void* in = ildz_open_file_read(path);
    path = string_remove_prefix(g_project_root_path, path);
    if (in == INVALID_HANDLE_VALUE) {
        logerr("Failed to open source file for reading: ", path);
        return false;
    }
    ASTNode* root = NULL;
    bool success = parse_ildz(
        in,
        path,
        &root,
        arena
    );
    CloseHandle(in);
    if (!success) {
        logerr("Parsing phase failed for file: ", path);
        return false;
    }
    *out_ast_root = root;
    loginfv("Successfully parsed into AST memory layer: ", path);
    return true;
}

#define MAX_FOUND_FILES 4096
#define MAX_FILE_NAME 260
static char g_found_files[MAX_FOUND_FILES][MAX_FILE_NAME];
static int g_found_file_count = 0;

bool compiler_cache_has_file(const char* path)
{
    // TODO:
    // Open binary cache
    // Search for file entry
    // Return true if found
    return false;
}

bool compiler_cache_file_modified(const char* path, WIN32_FIND_DATAA* find_data)
{
    // TODO:
    // Compare cached timestamp against find_data->ftLastWriteTime
    // Return true if changed
    return true;
}

void compile_directory_recursive(const char* dir_path, bool is_root_dir, Arena* arena)
{
    WIN32_FIND_DATAA find_data;
    char search_pattern[MAX_PATH];
    path_join(search_pattern, sizeof(search_pattern), dir_path, "*");
    void* handle = FindFirstFileA(search_pattern, &find_data);
    if (handle == INVALID_HANDLE_VALUE)
    {
        logerr("Failed to open directory: ", dir_path);
        ExitProcess(1);
        return;
    }
    do
    {
        if (find_data.cFileName[0] == '.' &&
            (find_data.cFileName[1] == '\0' ||
            (find_data.cFileName[1] == '.' && find_data.cFileName[2] == '\0')))
        {
            continue;
        }
        char full_path[MAX_PATH];
        path_join(full_path, sizeof(full_path), dir_path, find_data.cFileName);

        if (find_data.dwFileAttributes & 0x10)
        {
            loginfv("Entering subdirectory: ", full_path);
            compile_directory_recursive(full_path, false, arena);
        }
        else
        {
            if (string_has_extension(find_data.cFileName, ".ildz"))
            {
                // Store filename for final report
                if (g_found_file_count < MAX_FOUND_FILES)
                {
                    int i = 0;
                    while (find_data.cFileName[i] && i < MAX_FILE_NAME - 1)
                    {
                        g_found_files[g_found_file_count][i] = find_data.cFileName[i];
                        i++;
                    }
                    g_found_files[g_found_file_count][i] = '\0';

                    g_found_file_count++;
                }
                loginfv(".ildz source file detected: ", find_data.cFileName);
                if (compiler_cache_has_file(full_path))
                {
                    loginfv("Found cached compilation entry: ", find_data.cFileName);
                    if (!compiler_cache_file_modified(full_path, &find_data))
                    {
                        loginfv("File unchanged. Skipping compile: ", find_data.cFileName);
                        continue;
                    }
                    loginfv("File modified. Recompiling: ", find_data.cFileName);
                }
                else
                {
                    loginfv("No cache entry. Compiling: ", find_data.cFileName);
                }
                ASTNode* file_ast = NULL;
                if (compile_file(full_path, &file_ast, arena))
                {
                    loginfv("Compilation successful: ", find_data.cFileName);

                    if (g_ast_root_count < MAX_COMPILATION_UNITS)
                    {
                        g_ast_roots[g_ast_root_count++] = file_ast;
                    }
                    else
                    {
                        logerr("Exceeded maximum compiler translation units storage limits.");
                        ExitProcess(1);
                    }
                }
                else
                {
                    logerr("Compilation failed: ", find_data.cFileName);
                    ExitProcess(1);
                }
            }
        }
    } while (FindNextFileA(handle, &find_data));
    FindClose(handle);
    loginfv("Finished scanning directory: ", dir_path);
    if (g_found_file_count > 0)
    {
        char buffer[8192];
        buffer[0] = '\0';
        string_copy(buffer, "Files found:");
        for (int i = 0; i < g_found_file_count; i++)
        {
            string_concatenate(buffer, " - ");
            string_concatenate(buffer, g_found_files[i]);
        }
        loginfv(buffer);
    }
    else
    {
        logerr("No ILDZ source files found in directory: ", dir_path);
        ExitProcess(1);
    }
}

typedef int64_t (*JitFunction)(void);
#define _CrtSetDbgFlag(x) ((void)0)
#include "ic_cmd_line.def"
#include "ic_veh.def"

void mainCRTStartup(void) {
    AddVectoredExceptionHandler(1, VectoredHandler);
    _CrtSetDbgFlag(_CRTDBG_ALLOC_MEM_DF | _CRTDBG_CHECK_ALWAYS_DF);
    HANDLE process = GetCurrentProcess();
    SymSetOptions(SYMOPT_LOAD_LINES | SYMOPT_UNDNAME);
    SymInitialize(process, "srv*C:\\symbols*https://msdl.microsoft.com/download/symbols", TRUE);
    log_set_output(GetStdHandle((unsigned long)-11));
    char root_prog_path[MAX_PATH] = {0};
    parse_command_line_args(root_prog_path, MAX_PATH);
    loginfv("[CommandLine] Target file path successfully resolved: ", root_prog_path);
    if (g_ic_log_verbose) loginfv("Verbose logging enabled.");

    g_compiler_arena.capacity = 16 * 1024 * 1024; // 16 MB global workspace pool
    g_compiler_arena.memory = HeapAlloc(GetProcessHeap(), 0, g_compiler_arena.capacity);
    if (!g_compiler_arena.memory) {
        logerr("Fatal Error: Failed to allocate global compiler arena pool.");
        ExitProcess(1);
    }

    loginfv("Scanning targeted working directory scope root: ", g_project_root_path);
    compile_directory_recursive(g_project_root_path, true, &g_compiler_arena);
    loginf("Running multi-pass symbol resolution logic.");
    if (!resolve_unknown_symbols()) ExitProcess(0);

    execute_global_dead_code_elimination();

    loginf("Lowering AST representations down to IR.");
    IRProgram ir_program;
    ir_init(&ir_program, &g_compiler_arena);
    IRLowerContext ir_ctx = {
        .prog = &ir_program,
        .arena = &g_compiler_arena,
        .variables = {0}
    };
    for (u32 i = 0; i < g_ast_root_count; i++) {
        if (g_ast_roots[i] != NULL) {
            loginfrgb("Lowering root ", i);
            ir_lower_ast(&ir_ctx, g_ast_roots[i]);
        }
    }
    loginf("Allocating executable kernel space for machine bytecode emission.");
    JitBuffer jit_buf;
    if (!jit_buffer_init(&jit_buf, 65536)) { // Request 64KB engine execution room
        ExitProcess(1);
    }
    loginf("Encoding linear IR instructions down to raw x86-64 machine code...");
    x86_bytecode_gen(&ir_program, &jit_buf);
    loginfv("After bytecode gen.");
    if (g_ic_build_mode == IC_BUILD_MODE_JIT) {
        run_generated_bytecode(&jit_buf);
        loginfrgb("After bytecode run.");
    } 
    else if (g_ic_build_mode == IC_BUILD_MODE_EXE) {
        write_pe_executable(g_ic_program_path, jit_buf.bytes, jit_buf.size);
        loginfrgb("After executable writing.");
        if (g_build_mode_exe_launch_after_build) process_launch(g_ic_program_path);
    }
    jit_buffer_free(&jit_buf);
    ExitProcess(0);
}