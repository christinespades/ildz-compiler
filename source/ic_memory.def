
int memory_compare(const void* ptr1, const void* ptr2, unsigned int bytes_count) {
    const unsigned char* b1 = (const unsigned char*)ptr1;
    const unsigned char* b2 = (const unsigned char*)ptr2;

    for (unsigned int i = 0; i < bytes_count; i++) {
        if (b1[i] != b2[i]) {
            return (b1[i] < b2[i]) ? -1 : 1;
        }
    }
    
    return 0;
}

void memory_copy(void* dst, const void* src, size_t size)
{
    unsigned char* d = dst;
    const unsigned char* s = src;

    while (size--)
        *d++ = *s++;
}

bool memory_equal(const void* ptr1, const void* ptr2, unsigned int bytes_count)
{
    const unsigned char* b1 = (const unsigned char*)ptr1;
    const unsigned char* b2 = (const unsigned char*)ptr2;

    for (unsigned int i = 0; i < bytes_count; i++)
    {
        if (b1[i] != b2[i])
            return false;
    }

    return true;
}

void* memory_move(void* dest, const void* src, unsigned int count) {
    if (!dest || !src || count == 0) return dest;

    unsigned char* d = (unsigned char*)dest;
    const unsigned char* s = (const unsigned char*)src;

    // If source is ahead of destination, copy forward (left shift)
    if (d < s) {
        for (unsigned int i = 0; i < count; i++) {
            d[i] = s[i];
        }
    } 
    // If destination is ahead of source, copy backward to prevent overwriting
    else if (d > s) {
        for (unsigned int i = count; i > 0; i--) {
            d[i - 1] = s[i - 1];
        }
    }

    return dest;
}
