bool parse_ildz_loop(unsigned long bytes_read, char* buffer, Arena* arena, ASTNode* root_prog, const char* filename) {
    ParserCtx ctx = {
        .cursor = 0,
        .in_function_scope = false,
        .in_struct_scope = false,
        .expecting_empty_line = false,
        .total_paths = 0,
        .returning_paths = 0,
        .last_stmt = NULL,
        .last_return_was_unknown_symbol = true
    };

    while (ctx.cursor < bytes_read) {
        // Peek past any leading line spaces/tabs to identify line-starting comments
        u32 comment_peek = ctx.cursor;
        while (comment_peek < bytes_read && (buffer[comment_peek] == ' ' || buffer[comment_peek] == '\t')) {
            comment_peek++;
            loginflinev("Moving past empty space on ");
        }
        if (comment_peek < bytes_read && buffer[comment_peek] == '#') {
            ctx.cursor = comment_peek;
            if (!handle_comment_block(bytes_read, buffer, &ctx)) return false;
            loginflinev("Handled a comment block.");
            continue;
        }

        // Line Breaks & Whitespace Bounds
        if (buffer[ctx.cursor] == '\n' || buffer[ctx.cursor] == '\r') {
            loginflinev("About to handle a newline after");
            if (!handle_newline(bytes_read, buffer, &ctx, false)) return false;
            continue;
        }

        // Out-of-dent out of an active function scope block check
        if (ctx.in_function_scope && buffer[ctx.cursor] != ' ' && buffer[ctx.cursor] != '\t') {
            if (ctx.returning_paths < ctx.total_paths && ctx.last_return_was_unknown_symbol == false) {
                logerrline("Function ", ansi_italic(ctx.current_fn_node->lexeme), " must explicitly return along all execution paths. It has ", ctx.returning_paths, " returning paths out of a total of ", ctx.total_paths, " execution paths. ");
                return false;
            }
            ctx.in_function_scope = false;
            ctx.current_fn_node = NULL;
            ctx.last_stmt = NULL; // Stop attaching subsequent global nodes to this function's body!
            loginfline("Parsed the end of function ", ansi_italic(ctx.current_fn_node->lexeme), " on ");
            continue;
        }

        // Out-of-dent check out of an active struct scope block check
        if (ctx.in_struct_scope && buffer[ctx.cursor] != ' ' && buffer[ctx.cursor] != '\t') {
            // De-indentation safely closes structural boundary context
            ctx.in_struct_scope = false;
            // Leave cursor intact to evaluate what keyword this out-of-dented line belongs to
            loginflinev("Struct declaration ended by line returning to zero indentation. Expecting an empty line.");
            ctx.expecting_empty_line = true;
        }

        // Processing spacing layout skip safely
        if (!ctx.in_function_scope && !ctx.in_struct_scope && (buffer[ctx.cursor] == ' ' || buffer[ctx.cursor] == '\t')) {
            ctx.cursor++;
            loginflinev("Moving through space in global scope.");
            continue;
        }

        // Struct Declarations ('struct')
        if (!ctx.in_function_scope && !ctx.in_struct_scope && str_match_keyword(buffer, ctx.cursor, bytes_read, "struct", 6)) {
            if (!handle_struct_decl(bytes_read, buffer, arena, root_prog, &ctx)) return false;
            loginflinev("Handled first line of struct declaration. Expecting indented line with struct member next.");
            continue;
        }

        // Function Declarations ('fn')
        if (!ctx.in_function_scope && str_match_keyword(buffer, ctx.cursor, bytes_read, "fn", 2)) {
            if (!handle_function_decl(bytes_read, buffer, arena, root_prog, &ctx)) return false;
            continue;
        }

        // Indented Structural Code Block Trailing Evaluation
        if (ctx.in_struct_scope) {
            loginfline("Inside struct body scope. Current indentation level is ", ctx.current_indent, " and last statement was ", ctx.last_stmt != NULL ? enum_to_string(ASTNodeType, ctx.last_stmt->type): "(null");
            if (!handle_struct_body(bytes_read, buffer, arena, root_prog, &ctx)) return false;
            continue;
        }

        // Indented Code Block Trailing Evaluation
        if (ctx.in_function_scope) {
            loginfline("Inside function body scope. Current indentation level is ", ctx.current_indent, " and last statement was ", ctx.last_stmt != NULL ? enum_to_string(ASTNodeType, ctx.last_stmt->type): "(null");
            if (!handle_function_body(bytes_read, buffer, arena, root_prog, &ctx)) return false;
            continue;
        }
        else {
            loginfline("About to handle a global variable declaration on");
            if (!handle_global_var_decl(bytes_read, buffer, arena, root_prog, &ctx)) return false;
            continue;
        }
    }

    // EOF Boundaries
    if (ctx.in_function_scope && ctx.returning_paths < ctx.total_paths) {
        logerrline("File ended without returning a value along all execution paths.");
        return false;
    }
    loginfline("Reached end of file for ", filename, " on ");
    return true;
}

bool parse_ildz(void* file_handle, const char* filename, ASTNode** out_ast_root, Arena* arena)
{
    *out_ast_root = NULL;

    // Initialize tracking variables at file processing entry
    g_cur_line_no = 1;
    g_line[0] = '\0';
    g_current_file = filename;

    loginflinev("[Parser] Beginning compilation unit processing for file: ", filename);

    unsigned long file_size = GetFileSize(file_handle, NULL);
    if (file_size == 0 || file_size == 0xFFFFFFFF) {
        loginflinev("[Parser] Skipping file '", filename, "' (empty or invalid size: ", file_size, " bytes)");
        return true; 
    }

    loginflinev("[Parser] Reading ", file_size, " bytes into arena memory for '", filename, "'...");
    char* buffer = (char*)arena_alloc(arena, file_size + 1);
    if (!buffer)
    {
        logerr("Failed to allocate parser arena memory.");
        return false;
    }

    unsigned long bytes_read = 0;
    if (!ReadFile(file_handle, buffer, file_size, &bytes_read, NULL)) {
        logerr("Windows ReadFile operation failed.");
        return false;
    }
    buffer[bytes_read] = '\0'; 

    // Seed the logging container with line 1 text before parsing begins
    update_logging_line_context(buffer, 0, bytes_read);

    // Prepare structural AST Program Root
    ASTNode* root_prog = (ASTNode*)arena_alloc(arena, sizeof(ASTNode));
    root_prog->type = NODE_PROGRAM;
    root_prog->children = NULL;
    root_prog->next = NULL;
    *out_ast_root = root_prog;

    loginflinergb("[Parser] Created NODE_PROGRAM root for '", filename, "' at address ", enum_to_string(ASTNodeType, root_prog->type));

    loginflinev("[Parser] Entering main AST parse loop for '", filename, "'...");
    bool result = parse_ildz_loop(bytes_read, buffer, arena, root_prog, filename);
    
    loginflinev("[Parser] Finished parsing '", filename, "' (Status: ", result ? "SUCCESS" : "FAILED", ")");
    return result;
}