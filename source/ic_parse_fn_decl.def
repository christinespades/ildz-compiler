// Function Signature Declaration Processing ('fn')
// Function Signature Declaration Processing ('fn')
static bool handle_function_decl(unsigned long bytes_read, const char* buffer, Arena* arena, ASTNode* root_prog, ParserCtx* ctx) {
    loginfline("Processing function structure definition.");
    ctx->cursor += 2; // Skip "fn"
    
    if (ctx->cursor >= bytes_read || buffer[ctx->cursor] != ' ') {
        logerrline("Syntax Error: Expected space separation after 'fn' keyword declaration.");
        return false;
    }
    ctx->cursor++;

    // Extract Return Type
    StringView return_type;
    if (!parse_type_token(bytes_read, buffer, ctx, &return_type)) {
        logerrline("Syntax Error: Missing or invalid return type definition context.");
        return false;
    }

    // Extract Function Name & create ASTNode
    ASTNode* fn_node = parse_identifier_and_create_node(bytes_read, buffer, arena, ctx, NODE_FUNCTION, false);
    if (!fn_node) return false;

    // register_global_symbol links fn_node to root_prog->children automatically.
    // DO NOT manually loop and append fn_node here again, or it creates a self-referential cycle!
    if (!register_global_symbol(fn_node, root_prog, ctx, true)) {
        return false;
    }

    // Set active function tracking fields in context
    ctx->current_fn_node = fn_node;
    ctx->current_fn_type = return_type;

    ctx->local_symbol_count = 0; // Reset for new scope

    // Argument Processing Loop
    if (ctx->cursor < bytes_read && buffer[ctx->cursor] == ' ') {
        ctx->cursor++;
        while (ctx->cursor < bytes_read && buffer[ctx->cursor] != '\n' && buffer[ctx->cursor] != '\r') {
            while (ctx->cursor < bytes_read && buffer[ctx->cursor] == ' ') ctx->cursor++;
            if (ctx->cursor >= bytes_read || buffer[ctx->cursor] == '\n' || buffer[ctx->cursor] == '\r') break;

            unsigned long start_cursor = ctx->cursor;

            // 1. Scan Arg Type
            StringView arg_type;
            arg_type.data = &buffer[ctx->cursor];
            arg_type.length = 0;
            while (ctx->cursor < bytes_read && buffer[ctx->cursor] != ' ' && buffer[ctx->cursor] != '\n' && buffer[ctx->cursor] != '\r') {
                arg_type.length++; ctx->cursor++;
            }
            
            while (ctx->cursor < bytes_read && buffer[ctx->cursor] == ' ') ctx->cursor++;

            // 2. Scan Arg Identifier
            StringView arg_id;
            arg_id.data = &buffer[ctx->cursor];
            arg_id.length = 0;
            while (ctx->cursor < bytes_read && buffer[ctx->cursor] != ' ' && buffer[ctx->cursor] != ',' && buffer[ctx->cursor] != '\n' && buffer[ctx->cursor] != '\r') {
                arg_id.length++; ctx->cursor++;
            }

            // Register into local symbols
            if (arg_id.length > 0) {
                if (!register_local_symbol(ctx, arg_id, arg_type, VAR_LOCAL_PARAM)) return false;
            }

            while (ctx->cursor < bytes_read && buffer[ctx->cursor] == ' ') ctx->cursor++;
            if (ctx->cursor < bytes_read && buffer[ctx->cursor] == ',') ctx->cursor++;

            // Safety check: force cursor advance if no progress was made to avoid infinite loops
            if (ctx->cursor == start_cursor) {
                ctx->cursor++;
            }
        }
    }

    ctx->in_function_scope = true;
    ctx->total_paths = 1;
    ctx->returning_paths = 0;
    
    // Reset last_stmt to NULL so inner function statements attach to fn_node->children
    ctx->last_stmt = NULL; 

    loginfline("Handled header for ", return_type, " function ", ansi_italic(fn_node->lexeme), " taking ", ctx->local_symbol_count, " args on ");
    return true;
}