// 1. Local Variable Declaration Handler
static bool handle_local_var_decl(unsigned long bytes_read, const char* buffer, Arena* arena, ASTNode* root_prog, ParserCtx* ctx, StringView type_sv) {
    loginfline("Processing local variable declaration with type: ", type_sv, " on ");

    // 1. Skip spaces after type token ("u8")
    while (ctx->cursor < bytes_read && (buffer[ctx->cursor] == ' ' || buffer[ctx->cursor] == '\t')) {
        ctx->cursor++;
    }

    // 2. Parse variable name token directly
    StringView var_name;
    if (!parse_identifier_token(bytes_read, buffer, ctx, &var_name, true)) {
        logerrline("Failed to parse valid variable identifier after type ", type_sv);
        return false;
    }

    if (!register_local_symbol(ctx, var_name, type_sv, VAR_LOCAL_VAR)) return false;

    // 4. Allocate AST node for local declaration
    ASTNode* var_node = (ASTNode*)arena_alloc(arena, sizeof(ASTNode));
    var_node->type = NODE_VAR_DECL;
    var_node->lexeme = var_name;
    var_node->children = NULL;
    var_node->next = NULL;

    // 5. Attach to current function statement chain safely
    ASTNode* parent_scope = ctx->current_fn_node ? ctx->current_fn_node : root_prog;

    if (!parent_scope->children) {
        parent_scope->children = var_node;
    } else if (ctx->last_stmt) {
        ctx->last_stmt->next = var_node;
    } else {
        // Fallback: search for tail of children if last_stmt wasn't tracked
        ASTNode* curr = parent_scope->children;
        while (curr->next != NULL) {
            curr = curr->next;
        }
        curr->next = var_node;
    }
    ctx->last_stmt = var_node;

    // 6. Skip trailing spaces
    while (ctx->cursor < bytes_read && (buffer[ctx->cursor] == ' ' || buffer[ctx->cursor] == '\t')) {
        ctx->cursor++;
    }

    // 7. Check optional assignment 'eq'
    if (str_match_keyword(buffer, ctx->cursor, bytes_read, "eq", 2)) {
        ctx->cursor += 2; // skip "eq"
        loginfline("Found assignment 'eq' initialization for local variable: ", var_name);
        return handle_assignment_expression(bytes_read, buffer, arena, ctx, var_name, OP_PLAIN_ASSIGNMENT);
    }

    // 8. Validate line termination if no assignment operator was present
    if (!ensure_end_of_line(bytes_read, buffer, ctx)) {
        logerrline("Syntax Error: Unexpected tokens after variable declaration '", var_name, "'. Expected assignment operator 'eq' or end of line.");
        return false;
    }

    loginfline("Processed local ", type_sv, " variable declaration ", ansi_italic(var_name), " without assignment on ");
    return true;
}