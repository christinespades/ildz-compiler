void path_get_parent_dir(char* path) {
    int len = 0;
    while (path[len] != '\0') len++;
    
    // Walk backward from the end to find the last trailing slash
    for (int i = len - 1; i >= 0; i--) {
        if (path[i] == '\\' || path[i] == '/') {
            path[i] = '\0'; // Truncate the string at the slash boundary
            return;
        }
    }
    // If no slash is found, default to the local directory execution context
    path[0] = '.';
    path[1] = '\0';
}

// sprintf
unsigned int path_join(char *dest, unsigned int size, const char *dir, const char *file) {
    unsigned int total_len = 0;
    unsigned int written = 0;
    char last_char = '\0';

    // 1. Copy the directory path and normalize slashes to '\'
    if (dir) {
        while (*dir) {
            char c = *dir;
            if (c == '/') {
                c = '\\'; // Normalize forward slashes to backslashes
            }
            
            if (dest && written + 1 < size) {
                dest[written] = c;
                written++;
            }
            last_char = c;
            total_len++;
            dir++;
        }
    }

    // 2. Add the backslash separator ONLY if 'dir' didn't already end in one
    if (total_len > 0 && last_char != '\\') {
        if (dest && written + 1 < size) {
            dest[written] = '\\';
            written++;
        }
        total_len++;
    }

    // 3. Copy the filename
    if (file) {
        while (*file) {
            char c = *file;
            if (c == '/') {
                c = '\\'; // Keep it completely consistent
            }

            if (dest && written + 1 < size) {
                dest[written] = c;
                written++;
            }
            total_len++;
            file++;
        }
    }

    // 4. Always null-terminate if there is room in the buffer
    if (dest && size > 0) {
        if (written < size) {
            dest[written] = '\0';
        } else {
            dest[size - 1] = '\0';
        }
    }

    return total_len;
}